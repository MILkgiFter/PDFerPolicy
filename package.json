{
  "name": "pdfer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npx cap sync",
    "cap:sync:android": "npx cap sync android",
    "android:icons": "npx @capacitor/assets generate --android --assetPath assets --iconBackgroundColor \"#222326\" --iconBackgroundColorDark \"#222326\" --splashBackgroundColor \"#020617\" --splashBackgroundColorDark \"#020617\" --logoSplashScale 0.11 && node scripts/patch-android-adaptive-inset.mjs && node scripts/refine-launcher-icons.mjs",
    "android:assemble": "cd android && gradlew.bat assembleDebug",
    "android:apk": "npm run build && npm run cap:sync:android && npm run android:icons && npm run android:assemble",
    "android:bundle": "npm run build && npm run cap:sync:android && npm run android:icons && cd android && gradlew.bat bundleRelease",
    "site:sync-github-pages-docs": "node scripts/sync-github-pages-docs.mjs"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^7.14.2",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "sharp": "^0.32.6"
  }
}
