# Copy to keystore.properties in this folder (android/) and fill in real values.
# Never commit keystore.properties or the .jks file.
#
# Create a keystore (run from android folder):
#   keytool -genkeypair -v -storetype PKCS12 -keystore pdfer-release.jks -alias pdfer -keyalg RSA -keysize 2048 -validity 10000
#
# Paths are relative to the android/ folder.
storeFile=pdfer-release.jks
keyAlias=pdfer
storePassword=
keyPassword=
